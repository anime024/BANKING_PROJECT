<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Signup</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Segoe UI", Arial, sans-serif;
    }

    body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #e0eafc, #cfdef3);
    }

    .container {
        background: #fff;
        padding: 35px 30px;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        width: 90%;
        max-width: 380px;
        text-align: center;
    }

    h2 {
        margin-bottom: 10px;
        color: #222;
    }

    p {
        font-size: 13px;
        color: #666;
        margin-bottom: 15px;
    }

    .message {
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 15px;
        font-weight: 500;
        background: #fdeaea;
        color: #c0392b;
        border: 1px solid #f5b7b1;
    }

    form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    input {
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 10px;
        outline: none;
        transition: 0.2s;
    }

    input:focus {
        border-color: #28a745;
        box-shadow: 0 0 5px rgba(40,167,69,0.3);
    }

    button {
        padding: 12px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.2s;
    }

    .signup-btn {
        background: #28a745;
        color: white;
    }

    .signup-btn:hover {
        background: #1e7e34;
    }

    .home-btn {
        background: #6c757d;
        color: white;
    }

    .home-btn:hover {
        background: #565e64;
    }

    .btn-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 5px;
    }

</style>
</head>

<body>

<div class="container">

    <h2>Create Account</h2>
    <p>Join us by filling in your details</p>

    <% if ( message) { %>
        <div class="message">
            <%= message %>
        </div>
    <% } %>

    <form action="/signup" method="post">

        <input type="text" name="name" placeholder="Enter Name" required>
        <input type="email" name="email" placeholder="Enter Email" required>
        <input type="tel" name="phone" placeholder="Enter Phone Number" required>
        <input type="password" name="password" placeholder="Enter Password" required>

        <div class="btn-group">
            <button type="submit" class="signup-btn">Signup</button>

            <a href="/" style="text-decoration:none;">
                <button type="button" class="home-btn">Home</button>
            </a>
        </div>

    </form>

</div>

</body>
</html>