<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HomePage</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            text-align: center;
            margin: 0;
            padding: 0;
        }

        h1{
            margin-top: 60px;
            color: #333;
        }

        h2{
            color: #e63946;
        }

        .btn-container{
            margin-top: 30px;
        }

        .btn{
            display: inline-block;
            padding: 10px 18px;
            margin: 10px;
            text-decoration: none;
            color: white;
            background: #007bff;
            border-radius: 6px;
            font-size: 16px;
            transition: 0.2s;
        }

        .btn:hover{
            background: #0056b3;
        }

        .signup{
            background: #28a745;
        }

        .signup:hover{
            background: #1e7e34;
        }

        .dashboard{
            background: #ff9800;
        }

        .dashboard:hover{
            background: #e68900;
        }
    </style>
</head>

<body>

    <h1>HOMEPAGE</h1>

    <% if (message) { %>
        <h2><%= message %></h2>
    <% } %>

    <div class="btn-container">
        <a href="/login" class="btn">LOGIN</a>
        <a href="/signup" class="btn signup">SIGNUP</a>
        <a href="/user/dashboard" class="btn dashboard">DASHBOARD</a>
    </div>

</body>
</html>