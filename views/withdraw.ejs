<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Withdraw</title>

    <style>
        body{
            font-family: Arial;
            background:#f4f4f4;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
        }

        .box{
            background:white;
            padding:30px;
            border-radius:10px;
            width:300px;
            text-align:center;
            box-shadow:0 0 10px rgba(0,0,0,0.1);
        }

        input{
            width:90%;
            padding:10px;
            margin:10px 0;
        }

        button{
            padding:10px 15px;
            background:green;
            color:white;
            border:none;
            border-radius:5px;
            cursor:pointer;
        }

        button:hover{
            background:#0a7a0a;
        }

        a{
            display:block;
            margin-top:10px;
            font-size:12px;
        }
    </style>
</head>

<body>

<div class="box">

    <h2>Withdraw Money</h2>

    <% if (message) { %>
     <h2><%= message %></h2>
    <% } %>
    <form action="/user/withdraw" method="POST">

        <input 
            type="number" 
            name="amount" 
            placeholder="Enter amount" 
            required
        />

        <input 
            type="password" 
            name="password" 
            placeholder="Enter password"
            required
        />

        <button type="submit">Withdraw</button>

    </form>

    <a href="/user/dashboard">Back to Dashboard</a>

</div>

</body>
</html>