<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Password</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      margin-top: 100px;
    }

    form {
      width: 300px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    input, button {
      padding: 10px;
    }

    button {
      background: #007bff;
      color: white;
      border: none;
      cursor: pointer;
    }
  </style>
</head>
<body>

    <h1>Change Password </h1>

    <% if (message) { %>
        <div class="message">
            <%= message %>
        </div>
    <% } %>


  <form action="/change-password" method="POST">
    <input 
      type="password" 
      name="currentPassword" 
      placeholder="Current Password" 
      required
    >

    <input 
      type="password" 
      name="newPassword" 
      placeholder="New Password" 
      required
    >

    <button type="submit">Submit</button>
  </form>

</body>
</html>